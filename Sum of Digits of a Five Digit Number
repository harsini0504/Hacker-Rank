#include <stdio.h>
#include <math.h>

int main() {
	
    int n;
    int i=0;
    int sum = 0;
    scanf("%d", &n);
    //Complete the code to calculate the sum of the five digits on n.
    for(i=0;i<5;i++){
        sum += (n%((int)pow(10,(i+1)))- n%((int)(pow(10,i))))/((int)pow(10,i));
    }
    printf("%d",sum);
    return 0;
}
