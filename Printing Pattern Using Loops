#include <stdio.h>

int main() {
    int n;
    // Read input n
    if (scanf("%d", &n) != 1) return 0;

    int size = 2 * n - 1;

    for (int i = 0; i < size; i++) {
        for (int j = 0; j < size; j++) {
            // Find the minimum distance to the edges
            int min_i = i < size - 1 - i ? i : size - 1 - i;
            int min_j = j < size - 1 - j ? j : size - 1 - j;
            int min_dist = min_i < min_j ? min_i : min_j;
            
            // Print the value based on distance from the edge
            printf("%d ", n - min_dist);
        }
        printf("\n");
    }

    return 0;
}
